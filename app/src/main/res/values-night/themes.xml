<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Warungin" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->
        <item name="colorPrimary">@color/primary_green_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_dark</item>
        <item name="colorSecondary">@color/warning_orange_dark</item>
        <item name="colorOnSecondary">@color/black</item>
        
        <!-- Status bar styling -->
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="Theme.Warungin" parent="Base.Theme.Warungin" />
</resources>